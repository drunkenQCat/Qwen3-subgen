# Qwen3-ASR Subgen on AMD ROCm
FROM rocm/dev-ubuntu-22.04:7.2

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
        rocm-hip-libraries python3-pip \
        ffmpeg python3 curl gosu tzdata libsndfile1 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# PyTorch with ROCm 7.2 support
RUN python3 -m pip install --no-cache-dir -U --pre \
        torch torchaudio --index-url https://download.pytorch.org/whl/nightly/rocm7.2

# App dependencies
COPY requirements.txt /
RUN --mount=type=cache,target=/root/.cache/pip \
    python3 -m pip install -U -r /requirements.txt

# Application files
COPY entrypoint.sh /
WORKDIR /subgen
COPY launcher.py subgen.py language_code.py /subgen/
RUN mkdir -p /cache && chmod 777 /cache

ENV XDG_CACHE_HOME=/cache \
    HF_HOME=/cache/huggingface \
    MPLCONFIGDIR=/cache/matplotlib

ENTRYPOINT ["/entrypoint.sh"]
CMD ["python3", "-u", "launcher.py"]
