# Qwen3-ASR Model
ASR_MODEL=Qwen/Qwen3-ASR-0.6B
# ASR_MODEL=Qwen/Qwen3-ASR-1.7B  # larger, more accurate model

# Forced aligner for timestamped output (optional, requires additional GPU memory)
FORCED_ALIGNER_MODEL=Qwen/Qwen3-ForcedAligner-0.6B
USE_FORCED_ALIGNER=True

# Server
WEBHOOKPORT=9000
TRANSCRIBE_DEVICE=gpu
CUDA_VISIBLE_DEVICES=1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
DEBUG=False
CLEAR_VRAM_ON_COMPLETE=False
APPEND=False
